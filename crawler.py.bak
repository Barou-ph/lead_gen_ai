    ],
    "hospitality": [
        "khach san", "nha hang", "du lich",
        "resort", "lu hanh", "su kien",
    ],
    "healthcare": [
        "phong kham", "duoc pham", "y te",
        "nha khoa", "tham my", "spa",
    ],
    "realestate": [
        "bat dong san", "xay dung", "noi that",
        "kien truc", "dia oc",
    ],
